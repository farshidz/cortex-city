# Log and cache retention
CORTEX_APP_LOG_RETENTION_DAYS=14
CORTEX_TASK_LOG_RETENTION_DAYS=14
HOST_METRICS_RETENTION_DAYS=3
CORTEX_CACHE_RETENTION_DAYS=14
CORTEX_BROWSER_CACHE_RETENTION_DAYS=14

# Application-owned scratch space
CORTEX_TMP_DIR=/opt/cortex-city/app/tmp
CORTEX_TMP_SCAN_DIRS=/tmp:/opt/cortex-city/app/tmp
CORTEX_TMP_RETENTION_DAYS=2
CORTEX_PRUNE_OWNED_TMP_ALL=1
CORTEX_TMP_USE_LSOF=1

# Orphan review workspaces are swept more aggressively than general temp data.
CORTEX_REVIEW_WORKSPACE_ROOT=/opt/cortex-city/app/tmp/reviews
CORTEX_REVIEW_WORKSPACE_RETENTION_HOURS=6

# Only inactive, Cortex-owned Codex rollouts become eligible at this age.
CORTEX_CODEX_SESSIONS_DIR=/home/cortex/.codex/sessions
CORTEX_CODEX_SESSION_RETENTION_DAYS=30

CORTEX_NPM_CACHE_ACTION=clean
CORTEX_PNPM_STORE_ACTION=prune
