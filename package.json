{
  "name": "farshid-agent",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx src/orchestrator-worker.ts",
    "lint": "eslint",
    "test": "tsx --test $(find src \\( -name '*.test.ts' -o -name '*.test.tsx' \\) -type f | sort)",
    "test:coverage": "npm run test:coverage:lib && npm run test:coverage:app",
    "test:coverage:lib": "c8 --reporter=text --reporter=lcov --reports-dir=coverage/lib --check-coverage --lines 80 --functions 80 --statements 80 --branches 80 --exclude=\"src/app/**\" tsx --test $(find src -maxdepth 1 -name '*.test.ts' -type f | sort) $(find src/lib -name '*.test.ts' -type f | sort)",
    "test:coverage:app": "npm run test:coverage:app:api && npm run test:coverage:app:tsx",
    "test:coverage:app:api": "c8 --all --include=\"src/app/api/**/*.ts\" --exclude=\"**/*.test.ts\" --reporter=text --reporter=lcov --reports-dir=coverage/app-api --check-coverage --lines 80 --functions 80 --statements 80 --branches 80 tsx --test $(find src/app/api -name '*.test.ts' -type f | sort)",
    "test:coverage:app:tsx": "c8 --all --include=\"src/app/reviews/**/*.tsx\" --include=\"src/app/settings/page.tsx\" --include=\"src/app/tasks/**/session/page.tsx\" --exclude=\"**/*.test.tsx\" --reporter=text --reporter=lcov --reports-dir=coverage/app-tsx --check-coverage --lines 80 --functions 80 --statements 80 --branches 80 tsx --test src/app/pages.test.tsx"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.7",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "proper-lockfile": "^4.1.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.2.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "c8": "^10.1.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
